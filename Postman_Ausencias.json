          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "3000",
          "path": [
            "ausencias"
          ]
        },
        "description": "Obtiene la lista de todas las ausencias registradas"
      },
      "response": []
    },
    {
      "name": "Obtener Ausencias por Trabajador",
      "request": {
        "method": "GET",
        "header": [],
