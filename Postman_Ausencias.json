{
  "info": {
    "_postman_id": "ausencias-collection",
    "name": "Ausencias API",
    "description": "Colección para gestionar ausencias de trabajadores",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Crear Nueva Ausencia",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fecha_inicio\": \"2026-05-25\",\n  \"fecha_termino\": \"2026-05-27\",\n  \"tipo_ausencia\": \"Vacaciones\",\n  \"motivo\": \"Descanso personal\",\n  \"id_trabajador\": 1\n}"
        },
        "url": {
          "raw": "http://localhost:3000/ausencias",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "3000",
          "path": [
            "ausencias"
          ]
        },
        "description": "Crea una nueva ausencia para un trabajador específico. Todos los campos son obligatorios."
      },
      "response": []
    },
    {
      "name": "Obtener Todas las Ausencias",
      "request": {
