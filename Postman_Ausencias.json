        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"estado\": \"Aprobada\",\n  \"comentario_revision\": \"Ausencia aprobada correctamente\",\n  \"revisado_por\": 1\n}"
        },
        "url": {
          "raw": "http://localhost:3000/ausencias/1/revisar",
          "protocol": "http",
